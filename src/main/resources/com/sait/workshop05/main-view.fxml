<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="app-root" xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sait.workshop05.controllers.MainController">

    <children>

        <!-- Sidebar: 220px wide, full height -->
        <VBox prefWidth="220" styleClass="app-sidebar"
              AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.topAnchor="0">

            <!-- Brand -->
            <VBox>
                <padding><Insets top="20" left="20" bottom="16" right="20"/></padding>
                <ImageView fitHeight="36" fitWidth="160" pickOnBounds="true" preserveRatio="true">
                    <image><Image smooth="true" url="@bakery_logo.png"/></image>
                </ImageView>
                <Label text="Management System" styleClass="sidebar-brand-subtitle">
                    <VBox.margin><Insets top="4"/></VBox.margin>
                </Label>
            </VBox>

            <!-- Nav: Main -->
            <VBox>
                <padding><Insets top="16" bottom="8" left="12" right="12"/></padding>
                <Label text="MAIN" styleClass="sidebar-section-title">
                    <VBox.margin><Insets left="8" bottom="6"/></VBox.margin>
                </Label>
                <Button fx:id="btnDashboard" mnemonicParsing="false" onAction="#onDashboardClick"
                        prefWidth="196" styleClass="sidebar_button" text="Dashboard">
                    <VBox.margin><Insets bottom="2"/></VBox.margin>
                </Button>
                <Button fx:id="btnOrders" mnemonicParsing="false" onAction="#onOrdersClick"
                        prefWidth="196" styleClass="sidebar_button" text="Orders">
                    <VBox.margin><Insets bottom="2"/></VBox.margin>
                </Button>
            </VBox>

            <!-- Nav: Management -->
            <VBox>
                <padding><Insets top="8" bottom="8" left="12" right="12"/></padding>
                <Label text="MANAGEMENT" styleClass="sidebar-section-title">
                    <VBox.margin><Insets left="8" bottom="6"/></VBox.margin>
                </Label>
                <Button fx:id="btnProducts" mnemonicParsing="false" onAction="#onProductsClick"
                        prefWidth="196" styleClass="sidebar_button" text="Products">
                    <VBox.margin><Insets bottom="2"/></VBox.margin>
                </Button>
                <Button fx:id="btnCustomers" mnemonicParsing="false" onAction="#onCustomersClick"
                        prefWidth="196" styleClass="sidebar_button" text="Customers">
                    <VBox.margin><Insets bottom="2"/></VBox.margin>
                </Button>
                <Button fx:id="btnEmployees" mnemonicParsing="false" onAction="#onEmployeesClick"
                        prefWidth="196" styleClass="sidebar_button" text="Employees">
                    <VBox.margin><Insets bottom="2"/></VBox.margin>
                </Button>
                <Button fx:id="btnLocations" mnemonicParsing="false" onAction="#onLocationsClick"
                        prefWidth="196" styleClass="sidebar_button" text="Locations">
                    <VBox.margin><Insets bottom="2"/></VBox.margin>
                </Button>
                <Button fx:id="btnUsers" mnemonicParsing="false" onAction="#onUsersClick"
                        prefWidth="196" styleClass="sidebar_button" text="Users">
                    <VBox.margin><Insets bottom="2"/></VBox.margin>
                </Button>
            </VBox>

            <!-- Nav: System -->
            <VBox>
                <padding><Insets top="8" bottom="8" left="12" right="12"/></padding>
                <Label text="SYSTEM" styleClass="sidebar-section-title">
                    <VBox.margin><Insets left="8" bottom="6"/></VBox.margin>
                </Label>
                <Button fx:id="btnRewards" mnemonicParsing="false" onAction="#onRewardsClick"
                        prefWidth="196" styleClass="sidebar_button" text="Rewards">
                    <VBox.margin><Insets bottom="2"/></VBox.margin>
                </Button>
                <Button fx:id="btnRewardTier" mnemonicParsing="false" onAction="#onRewardTierClick"
                        prefWidth="196" styleClass="sidebar_button" text="Reward Tiers">
                    <VBox.margin><Insets bottom="2"/></VBox.margin>
                </Button>
                <Button fx:id="btnMessages" mnemonicParsing="false" onAction="#onMessagesClick"
                        prefWidth="196" styleClass="sidebar_button" text="Messages">
                    <VBox.margin><Insets bottom="2"/></VBox.margin>
                </Button>
                <Button fx:id="btnAnalytics" mnemonicParsing="false" onAction="#onAnalyticsClick"
                        prefWidth="196" styleClass="sidebar_button" text="Analytics">
                    <VBox.margin><Insets bottom="2"/></VBox.margin>
                </Button>
                <Button fx:id="btnActivityLog" mnemonicParsing="false" onAction="#onActivityLogClick"
                        prefWidth="196" styleClass="sidebar_button" text="Activity Log">
                    <VBox.margin><Insets bottom="2"/></VBox.margin>
                </Button>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- User info block -->
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-user-block">
                <Label fx:id="lblInitials" text="?" styleClass="sidebar-user-initials"/>
                <VBox spacing="2">
                    <Label fx:id="lblUsername" text="User" styleClass="sidebar-user-name"/>
                    <Label fx:id="lblRole" text="Role" styleClass="sidebar-user-role"/>
                </VBox>
            </HBox>

            <!-- Logout -->
            <VBox>
                <padding><Insets top="4" bottom="12" left="12" right="12"/></padding>
                <Button id="btnLogout" fx:id="btnLogout" mnemonicParsing="false"
                        onAction="#onLogoutClick" prefWidth="196"
                        styleClass="sidebar_button" text="Log out"/>
            </VBox>

        </VBox>

        <!-- Top bar: page title -->
        <HBox alignment="CENTER_LEFT" styleClass="page-title-bar"
              AnchorPane.leftAnchor="220" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <padding><Insets left="24" right="24"/></padding>
            <Label fx:id="lblPageTitle" text="Dashboard" styleClass="page-title-bar-title"/>
        </HBox>

        <!-- Content area -->
        <AnchorPane fx:id="contentArea" styleClass="app-content"
                    AnchorPane.bottomAnchor="0"
                    AnchorPane.leftAnchor="220"
                    AnchorPane.rightAnchor="0"
                    AnchorPane.topAnchor="56"/>

    </children>
</AnchorPane>
