<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sait.workshop05.controllers.MainController">

   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>

   <children>

      <VBox prefWidth="191.0" style="-fx-background-color: #C19A6B;" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.topAnchor="0">

         <children>

            <VBox prefHeight="63.0" prefWidth="191.0">
               <children>
                  <ImageView fitHeight="44.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image smooth="true" url="@bakery_logo.png" />
                     </image>
                  </ImageView>
                  <Label text="Management System" />
               </children>
               <padding>
                  <Insets left="20.0" top="15.0" />
               </padding>
            </VBox>

            <VBox prefHeight="143.0" prefWidth="191.0">
               <children>
                  <Label text="Main">
                     <font>
                        <Font name="JetBrainsMonoNL NF ExtraBold Italic" size="16.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="10.0" left="15.0" />
                     </VBox.margin>
                  </Label>

                  <Button fx:id="btnDashboard" mnemonicParsing="false" onAction="#onDashboardClick" prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Dashboard">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>

                  <Button fx:id="btnOrders" mnemonicParsing="false" onAction="#onOrdersClick" prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Orders">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="15.0" top="15.0" />
               </padding>
            </VBox>

            <VBox prefHeight="165.0" prefWidth="191.0">
               <children>
                  <Label text="Management">
                     <font>
                        <Font name="JetBrainsMonoNL NF ExtraBold Italic" size="16.0" />
                     </font>
                     <VBox.margin>
                        <Insets left="15.0" />
                     </VBox.margin>
                  </Label>

                  <Button fx:id="btnProducts" mnemonicParsing="false" onAction="#onProductsClick" prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Products">
                     <VBox.margin>
                        <Insets bottom="10.0" top="10.0" />
                     </VBox.margin>
                  </Button>

                  <Button fx:id="btnCustomers" mnemonicParsing="false" onAction="#onCustomersClick" prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Customers">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>

                  <Button fx:id="btnEmployees" mnemonicParsing="false" onAction="#onEmployeesClick" prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Employees">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>

                  <Button fx:id="btnLocations" mnemonicParsing="false" onAction="#onLocationsClick" prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Locations">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>

               </children>
               <padding>
                  <Insets bottom="15.0" top="15.0" />
               </padding>
            </VBox>

            <VBox prefHeight="203.0" prefWidth="191.0">
               <children>
                  <Label text="System">
                     <font>
                        <Font name="JetBrainsMonoNL NF ExtraBold Italic" size="16.0" />
                     </font>
                     <VBox.margin>
                        <Insets left="15.0" />
                     </VBox.margin>
                  </Label>

                  <Button fx:id="btnRewards" mnemonicParsing="false" onAction="#onRewardsClick" prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Rewards">
                     <VBox.margin>
                        <Insets bottom="10.0" top="10.0" />
                     </VBox.margin>
                  </Button>

                  <Button fx:id="btnRewardTier" mnemonicParsing="false" onAction="#onRewardTierClick"
                          prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Reward Tiers">
                     <VBox.margin>
                        <Insets bottom="10.0"/>
                     </VBox.margin>
                  </Button>

                  <Button fx:id="btnMessages" mnemonicParsing="false" onAction="#onMessagesClick"
                          prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Messages">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>

                  <Button fx:id="btnAnalytics" mnemonicParsing="false" onAction="#onAnalyticsClick" prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Analytics">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>

                  <Button fx:id="btnActivityLog" mnemonicParsing="false" onAction="#onActivityLogClick" prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Activity Log">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>

               </children>
               <padding>
                  <Insets bottom="15.0" top="15.0" />
               </padding>
            </VBox>

            <!-- Spacer to push logout to bottom -->
            <Region VBox.vgrow="ALWAYS" />

            <!-- Logout Section -->
            <VBox prefWidth="191.0">
               <children>
                  <Button fx:id="btnLogout" mnemonicParsing="false" onAction="#onLogoutClick" prefHeight="25.0" prefWidth="204.0" style="-fx-text-fill: red" styleClass="sidebar_button" text="Logout">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="15.0" top="5.0" />
               </padding>
            </VBox>

         </children>
      </VBox>

      <HBox alignment="CENTER_RIGHT" prefHeight="61.0" prefWidth="1003.0" style="-fx-background-color: #F7F7F7;" AnchorPane.leftAnchor="191.0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

         <children>

            <VBox alignment="CENTER_RIGHT" prefHeight="57.0" prefWidth="311.0">
               <HBox.margin>
                  <Insets bottom="2.0" left="150.0" right="5.0" top="2.0" />
               </HBox.margin>
               <children>
                  <Label fx:id="lblUsername">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="3.0" />
                     </VBox.margin></Label>
                  <Label fx:id="lblRole">
                     <VBox.margin>
                        <Insets bottom="5.0" />
                     </VBox.margin>
                     <font>
                        <Font name="System Italic" size="12.0" />
                     </font></Label>
               </children>
               <padding>
                  <Insets right="30.0" />
               </padding>
            </VBox>
         </children>
      </HBox>

      <AnchorPane fx:id="contentArea" style="-fx-background-color: white;" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="191.0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="61.0" />
   </children>
</AnchorPane>
