<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane styleClass="app-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sait.workshop05.controllers.MainController">

   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>

   <children>

      <VBox prefWidth="191.0" styleClass="app-sidebar" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.topAnchor="0">

         <children>

            <VBox prefHeight="63.0" prefWidth="191.0">
               <children>
                  <ImageView fitHeight="44.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image smooth="true" url="@bakery_logo.png" />
                     </image>
                  </ImageView>
                  <Label text="Management System" styleClass="sidebar-brand-subtitle" />
               </children>
               <padding>
                  <Insets left="20.0" top="15.0" />
               </padding>
            </VBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        styleClass="sidebar-scroll" VBox.vgrow="ALWAYS">
               <content>
                  <VBox prefWidth="191.0">
                     <children>
            <VBox prefHeight="143.0" prefWidth="191.0">
               <children>
                  <Label text="Main" styleClass="sidebar-section-title">
                     <VBox.margin>
                        <Insets bottom="10.0" left="15.0" />
                     </VBox.margin>
                  </Label>

                  <Button fx:id="btnDashboard" mnemonicParsing="false" onAction="#onDashboardClick" prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Dashboard">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>

                  <Button fx:id="btnOrders" mnemonicParsing="false" onAction="#onOrdersClick" prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Orders">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="5.0" top="5.0" />
               </padding>
            </VBox>

            <!-- Nav: Management -->
            <VBox prefWidth="191.0">
               <children>
                  <Label text="Management" styleClass="sidebar-section-title">
                     <VBox.margin>
                        <Insets bottom="10.0" left="15.0" />
                     </VBox.margin>
                  </Label>
                  <Button fx:id="btnProducts" mnemonicParsing="false" onAction="#onProductsClick"
                          prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Products">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>
                  <Button fx:id="btnProductSpecials" mnemonicParsing="false" onAction="#onProductSpecialsClick"
                          prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Product Specials">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>
                  <Button fx:id="btnCustomers" mnemonicParsing="false" onAction="#onCustomersClick"
                          prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Customers">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>
                  <Button fx:id="btnEmployees" mnemonicParsing="false" onAction="#onEmployeesClick"
                          prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Employees">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>
                  <Button fx:id="btnLocations" mnemonicParsing="false" onAction="#onLocationsClick"
                          prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Locations">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>
                  <Button fx:id="btnUsers" mnemonicParsing="false" onAction="#onUsersClick"
                          prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Users">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="5.0" top="5.0" />
               </padding>
            </VBox>

            <VBox prefHeight="203.0" prefWidth="191.0">
               <children>
                  <Label text="System" styleClass="sidebar-section-title">
                     <VBox.margin>
                        <Insets bottom="10.0" left="15.0" />
                     </VBox.margin>
                  </Label>

                  <Button fx:id="btnRewards" mnemonicParsing="false" onAction="#onRewardsClick" prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Rewards">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>

                  <Button fx:id="btnRewardTier" mnemonicParsing="false" onAction="#onRewardTierClick"
                          prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Reward Tiers">
                     <VBox.margin>
                        <Insets bottom="10.0"/>
                     </VBox.margin>
                  </Button>

                  <Button fx:id="btnMessages" mnemonicParsing="false" onAction="#onMessagesClick"
                          prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Support Chat">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>

                  <Button fx:id="btnActivityLog" mnemonicParsing="false" onAction="#onActivityLogClick" prefHeight="25.0" prefWidth="204.0" styleClass="sidebar_button" text="Activity Log">
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Button>

               </children>
               <padding>
                  <Insets bottom="5.0" top="5.0" />
               </padding>
            </VBox>

                     </children>
                  </VBox>
               </content>
            </ScrollPane>

            <!-- User info block -->
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-user-block">
                <StackPane minWidth="36" minHeight="36" maxWidth="36" maxHeight="36" styleClass="sidebar-user-avatar-wrap">
                    <ImageView fx:id="imgUserAvatar" fitWidth="36" fitHeight="36" pickOnBounds="true" preserveRatio="true"
                               visible="false" managed="false"/>
                    <Label fx:id="lblInitials" text="?" styleClass="sidebar-user-initials"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="lblUsername" text="User" styleClass="sidebar-user-name"/>
                    <Label fx:id="lblRole" text="Role" styleClass="sidebar-user-role"/>
                </VBox>
            </HBox>

            <!-- Logout -->
            <VBox>
                <padding><Insets top="4" bottom="12" left="12" right="12"/></padding>
                <Button id="btnLogout" fx:id="btnLogout" mnemonicParsing="false"
                        onAction="#onLogoutClick" prefWidth="196"
                        styleClass="sidebar_button" text="Log out"/>
            </VBox>

         </children>
      </VBox>

      <HBox alignment="CENTER_LEFT" prefHeight="61.0" styleClass="app-top-bar" AnchorPane.leftAnchor="191.0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
         <padding>
            <Insets left="24.0" right="24.0"/>
         </padding>
         <children>
            <Label fx:id="lblPageTitle" styleClass="app-page-title" text="Dashboard"/>
         </children>
      </HBox>

      <AnchorPane fx:id="contentArea" styleClass="app-content" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="191.0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="61.0" />
   </children>
</AnchorPane>
