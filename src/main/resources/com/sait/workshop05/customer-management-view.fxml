<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.6"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sait.workshop05.controllers.CustomerManagementController"
            prefWidth="1200" prefHeight="800"
            styleClass="page-root">

    <children>

        <VBox spacing="12"
              AnchorPane.topAnchor="0"
              AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0"
              fillWidth="true">

            <padding>
                <Insets top="14" right="14" bottom="14" left="14"/>
            </padding>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Customer Management" styleClass="page-title"/>

                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtSearch" promptText="Search customers..."
                           prefWidth="260" styleClass="toolbar-search"/>
                <Button fx:id="btnNewCustomer" text="New Customer" onAction="#onNewCustomer"
                        styleClass="btn-accent toolbar-action"/>
                <Button fx:id="btnOrderHistory" text="Order History"
                        onAction="#onViewOrderHistory"
                        styleClass="btn-muted toolbar-action" disable="true"/>
                <Button fx:id="btnAdjustPoints" text="Adjust Points"
                        onAction="#onAdjustPoints"
                        styleClass="btn-muted toolbar-action" disable="true"/>
                <Button fx:id="btnRefresh" text="Refresh" onAction="#onRefresh"
                        styleClass="btn-muted toolbar-action"/>
            </HBox>

            <!-- Table -->
            <TableView fx:id="tblCustomers" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colFirstName" text="FIRST NAME" prefWidth="120"/>
                    <TableColumn fx:id="colLastName" text="LAST NAME" prefWidth="120"/>
                    <TableColumn fx:id="colEmail" text="EMAIL" prefWidth="200"/>
                    <TableColumn fx:id="colPhone" text="PHONE" prefWidth="130"/>
                    <TableColumn fx:id="colRewardTier" text="TIER" prefWidth="90"/>
                    <TableColumn fx:id="colRewardBalance" text="POINTS" prefWidth="80"/>
                    <TableColumn fx:id="colAddress" text="ADDRESS" prefWidth="180"/>
                    <TableColumn fx:id="colActions" text="" prefWidth="80"/>
                </columns>
            </TableView>

            <Label fx:id="lblStatus" text="" styleClass="hint-label"/>
        </VBox>
    </children>
</AnchorPane>
