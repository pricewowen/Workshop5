<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sait.workshop05.RewardController"
            prefWidth="1200" prefHeight="800"
            style="-fx-background-color: white;">
    <children>
        <VBox spacing="12"
              AnchorPane.topAnchor="0"
              AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0"
              fillWidth="true">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14"/>
            </padding>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Reward Management">
                    <font>
                        <Font size="24"/>
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Search:" style="-fx-font-size: 13px;"/>
                <TextField fx:id="txtSearch"
                           promptText="Search rewards..."
                           prefWidth="420"
                           style="-fx-font-size: 13px;"/>
                <Button text="Refresh"
                        fx:id="btnRefresh"
                        onAction="#onRefresh"
                        prefWidth="100"
                        style="-fx-font-size: 13px;"/>
            </HBox>
            <SplitPane dividerPositions="0.70" VBox.vgrow="ALWAYS" prefWidth="1.0" prefHeight="1.0">
                <items>
                    <VBox spacing="10" SplitPane.resizableWithParent="true" fillWidth="true">
                        <TableView fx:id="tblRewards"
                                   VBox.vgrow="ALWAYS"
                                   prefWidth="1.0"
                                   style="-fx-font-size: 13px;">
                            <fixedCellSize>28</fixedCellSize>
                            <columns>
                                <TableColumn fx:id="colRewardId" text="ID" prefWidth="60"/>
                                <TableColumn fx:id="colCustomer" text="Customer" prefWidth="200"/>
                                <TableColumn fx:id="colOrder" text="Order" prefWidth="200"/>
                                <TableColumn fx:id="colPoints" text="Points" prefWidth="80"/>
                                <TableColumn fx:id="colTransactionDate" text="Transaction Date" prefWidth="180"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                        <Label fx:id="lblStatus"
                               text="0 reward(s) loaded"
                               style="-fx-text-fill: #444; -fx-font-size: 13px;"/>
                    </VBox>
                    <ScrollPane fitToWidth="true"
                                fitToHeight="true"
                                hbarPolicy="NEVER"
                                vbarPolicy="AS_NEEDED"
                                prefWidth="420"
                                SplitPane.resizableWithParent="true">
                        <content>
                            <VBox spacing="14"
                                  fillWidth="true"
                                  prefWidth="1.0"
                                  style="-fx-background-color: #fafafa; -fx-border-color: #e6e6e6;">
                                <padding>
                                    <Insets top="16" right="16" bottom="16" left="16"/>
                                </padding>
                                <Label text="Reward Details" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                                <GridPane hgap="12" vgap="12" prefWidth="1.0">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="150"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>
                                    <Label text="Reward ID:" style="-fx-font-size: 13px;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                    <TextField fx:id="txtRewardId" editable="false" promptText="Auto" style="-fx-font-size: 13px;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                    <Label text="Customer:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                    <ComboBox fx:id="cboCustomer" style="-fx-font-size: 13px;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                    <Label text="Order:" style="-fx-font-size: 13px;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                    <ComboBox fx:id="cboOrder" style="-fx-font-size: 13px;" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                    <Label text="Points Earned:" style="-fx-font-size: 13px;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                    <TextField fx:id="txtPoints" style="-fx-font-size: 13px;" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                                    <Label text="Transaction Date:" style="-fx-font-size: 13px;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                    <HBox spacing="5" style="-fx-font-size: 13px;" GridPane.rowIndex="4" GridPane.columnIndex="1">
                                        <DatePicker fx:id="dtpTransactionDate" prefWidth="150"/>
                                        <TextField fx:id="txtTransactionTime" promptText="HH:MM" prefWidth="60"/>
                                    </HBox>
                                </GridPane>
                                <Separator/>
                                <HBox spacing="12">
                                    <Button text="Create" fx:id="btnCreate" onAction="#onCreate"
                                            prefHeight="38" style="-fx-font-size: 13px;"
                                            HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                                    <Button text="Update" fx:id="btnUpdate" onAction="#onUpdate"
                                            prefHeight="38" style="-fx-font-size: 13px;"
                                            HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                                </HBox>
                                <HBox spacing="12">
                                    <Button text="Delete" fx:id="btnDelete" onAction="#onDelete"
                                            prefHeight="38" style="-fx-font-size: 13px;"
                                            HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                                    <Button text="Clear" fx:id="btnClear" onAction="#onClear"
                                            prefHeight="38" style="-fx-font-size: 13px;"
                                            HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                                </HBox>
                                <Label text="* required" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                            </VBox>
                        </content>
                    </ScrollPane>
                </items>
            </SplitPane>
        </VBox>
    </children>
</AnchorPane>