<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="800" prefWidth="1200" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sait.workshop05.controllers.RewardController">
    <children>
        <VBox fillWidth="true" spacing="12" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <padding>
                <Insets bottom="14" left="14" right="14" top="14" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="Reward Management">
                    <font>
                        <Font size="24" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Label style="-fx-font-size: 13px;" text="Search:" />
                <TextField fx:id="txtSearch" prefWidth="420" promptText="Search rewards..." style="-fx-font-size: 13px;" />
                <Button fx:id="btnRefresh" onAction="#onRefresh" prefWidth="100" style="-fx-font-size: 13px;" text="Refresh" />
            </HBox>
            <SplitPane dividerPositions="0.7" prefHeight="1.0" prefWidth="1.0" VBox.vgrow="ALWAYS">
                <items>
                    <VBox fillWidth="true" spacing="10" SplitPane.resizableWithParent="true">
                        <TableView fx:id="tblRewards" prefWidth="1.0" style="-fx-font-size: 13px;" VBox.vgrow="ALWAYS">
                            <fixedCellSize>28</fixedCellSize>
                            <columns>
                                <TableColumn fx:id="colRewardId" prefWidth="60" text="ID" />
                                <TableColumn fx:id="colCustomer" prefWidth="200" text="Customer" />
                                <TableColumn fx:id="colOrder" prefWidth="200" text="Order" />
                                <TableColumn fx:id="colPoints" prefWidth="80" text="Points" />
                                <TableColumn fx:id="colTransactionDate" prefWidth="180" text="Transaction Date" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                        <Label fx:id="lblStatus" style="-fx-text-fill: #444; -fx-font-size: 13px;" text="0 reward(s) loaded" />
                    </VBox>
                    <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" prefWidth="420" vbarPolicy="AS_NEEDED" SplitPane.resizableWithParent="true">
                        <content>
                            <VBox fillWidth="true" prefWidth="1.0" spacing="14" style="-fx-background-color: #fafafa; -fx-border-color: #e6e6e6;">
                                <padding>
                                    <Insets bottom="16" left="16" right="16" top="16" />
                                </padding>
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Reward Details" />
                                <GridPane hgap="12" prefWidth="1.0" vgap="12">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="150" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <Label style="-fx-font-size: 13px;" text="Reward ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                    <TextField fx:id="txtRewardId" editable="false" promptText="Auto" style="-fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                    <Label text="Customer:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                    <ComboBox fx:id="cboCustomer" prefHeight="27.0" prefWidth="150.0" style="-fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                    <Label style="-fx-font-size: 13px;" text="Order:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                    <ComboBox fx:id="cboOrder" prefHeight="27.0" prefWidth="150.0" style="-fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                    <Label style="-fx-font-size: 13px;" text="Points Earned:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                    <TextField fx:id="txtPoints" style="-fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                    <Label style="-fx-font-size: 13px;" text="Transaction Date:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                    <HBox spacing="5" style="-fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="4">
                                        <DatePicker fx:id="dtpTransactionDate" prefWidth="150" />
                                        <TextField fx:id="txtTransactionTime" prefWidth="60" promptText="HH:MM" />
                                    </HBox>
                           <rowConstraints>
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                           </rowConstraints>
                                </GridPane>
                                <Separator />
                                <HBox spacing="12">
                                    <Button fx:id="btnCreate" maxWidth="1.7976931348623157E308" onAction="#onCreate" prefHeight="38" style="-fx-font-size: 13px;" text="Create" HBox.hgrow="ALWAYS" />
                                    <Button fx:id="btnUpdate" maxWidth="1.7976931348623157E308" onAction="#onUpdate" prefHeight="38" style="-fx-font-size: 13px;" text="Update" HBox.hgrow="ALWAYS" />
                                </HBox>
                                <HBox spacing="12">
                                    <Button fx:id="btnDelete" maxWidth="1.7976931348623157E308" onAction="#onDelete" prefHeight="38" style="-fx-font-size: 13px;" text="Delete" HBox.hgrow="ALWAYS" />
                                    <Button fx:id="btnClear" maxWidth="1.7976931348623157E308" onAction="#onClear" prefHeight="38" style="-fx-font-size: 13px;" text="Clear" HBox.hgrow="ALWAYS" />
                                </HBox>
                                <Label style="-fx-text-fill: #666; -fx-font-size: 12px;" text="* required" />
                            </VBox>
                        </content>
                    </ScrollPane>
                </items>
            </SplitPane>
        </VBox>
    </children>
</AnchorPane>
