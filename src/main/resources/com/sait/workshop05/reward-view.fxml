<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="800" prefWidth="1200" styleClass="page-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sait.workshop05.controllers.RewardController">
    <children>
        <VBox fillWidth="true" spacing="12" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <padding>
                <Insets bottom="14" left="14" right="14" top="14" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="Reward Management" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS" />
                <Label style="-fx-font-size: 13px;" text="Search:" />
                <TextField fx:id="txtSearch" prefWidth="420" promptText="Search rewards..." style="-fx-font-size: 13px;" />
                <Button fx:id="btnRefresh" onAction="#onRefresh" prefWidth="100" styleClass="btn-muted" text="Refresh" />
            </HBox>
            <SplitPane dividerPositions="0.7" prefHeight="1.0" prefWidth="1.0" VBox.vgrow="ALWAYS">
                <items>
                    <VBox fillWidth="true" spacing="10" SplitPane.resizableWithParent="true">
                        <TableView fx:id="tblRewards" prefWidth="1.0" style="-fx-font-size: 13px;" VBox.vgrow="ALWAYS">
                            <fixedCellSize>28</fixedCellSize>
                            <columns>
                                <TableColumn fx:id="colCustomer" prefWidth="200" text="Customer" />
                                <TableColumn fx:id="colOrder" prefWidth="200" text="Order" />
                                <TableColumn fx:id="colPoints" prefWidth="80" text="Points" />
                                <TableColumn fx:id="colTransactionDate" prefWidth="180" text="Transaction Date" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                        <Label fx:id="lblStatus" style="-fx-text-fill: #444; -fx-font-size: 13px;" text="0 reward(s) loaded" />
                    </VBox>
                    <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" prefWidth="420" vbarPolicy="AS_NEEDED" SplitPane.resizableWithParent="true">
                        <content>
                            <VBox fillWidth="true" prefWidth="1.0" spacing="14" styleClass="form-panel">
                                <padding>
                                    <Insets bottom="16" left="16" right="16" top="16" />
                                </padding>
                                <Label styleClass="form-panel-title" text="Reward Details" />
                                <GridPane hgap="12" prefWidth="1.0" vgap="12">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="150" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <Label text="Customer:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                    <ComboBox fx:id="cboCustomer" disable="true" prefHeight="27.0" prefWidth="150.0" style="-fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                    <Label style="-fx-font-size: 13px;" text="Order:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                    <ComboBox fx:id="cboOrder" disable="true" prefHeight="27.0" prefWidth="150.0" style="-fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                    <Label style="-fx-font-size: 13px;" text="Points Earned:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                    <TextField fx:id="txtPoints" editable="false" style="-fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                    <Label style="-fx-font-size: 13px;" text="Transaction Date:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                    <HBox spacing="5" style="-fx-font-size: 13px;" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                        <DatePicker fx:id="dtpTransactionDate" disable="true" prefWidth="150" />
                                        <TextField fx:id="txtTransactionTime" editable="false" prefWidth="60" promptText="HH:MM" />
                                    </HBox>
                           <rowConstraints>
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                           </rowConstraints>
                                </GridPane>
                                <Separator />
                                <Label style="-fx-text-fill: #8A8178; -fx-font-size: 12px; -fx-wrap-text: true;"
                                       text="Reward transactions are read-only. Points are awarded automatically when orders are placed." />
                                <Button fx:id="btnClear" maxWidth="1.7976931348623157E308" onAction="#onClear" prefHeight="38" styleClass="btn-muted" text="Clear Selection" />
                            </VBox>
                        </content>
                    </ScrollPane>
                </items>
            </SplitPane>
        </VBox>
    </children>
</AnchorPane>
