<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sait.workshop05.RegistrationController"
            prefHeight="850.0" prefWidth="850.0"
            style="-fx-background-color: #f5f5f5;">

    <center>
        <VBox alignment="CENTER" spacing="25">
            <padding>
                <Insets top="40" right="50" bottom="40" left="50"/>
            </padding>

            <!-- Registration Card -->
            <VBox alignment="CENTER" spacing="20"
                  style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);"
                  prefWidth="450" maxWidth="450">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>

                <!-- Header -->
                <VBox alignment="CENTER" spacing="10">
                    <Label text="🥐 Peelin' Good Bakery" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #C19A6B;"/>
                    <Label fx:id="roleLabel" text="Create Account" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                    <Label text="Join our bakery community today!" style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
                </VBox>

                <Separator prefWidth="370"/>

                <!-- Registration Form -->
                <VBox spacing="15" prefWidth="370">
                    <!-- Username Field -->
                    <VBox spacing="5">
                        <Label text="Username *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                        <TextField fx:id="usernameField"
                                   promptText="Choose a username (letters, numbers, underscore)"
                                   style="-fx-font-size: 14px; -fx-background-radius: 5; -fx-border-color: #cccccc; -fx-border-radius: 5;"
                                   prefHeight="40"/>
                        <Label text="3-50 characters, alphanumeric and underscore only"
                               style="-fx-font-size: 11px; -fx-text-fill: #999999;"/>
                    </VBox>

                    <!-- Email Field -->
                    <VBox spacing="5">
                        <Label text="Email Address *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                        <TextField fx:id="emailField"
                                   promptText="your.email@example.com"
                                   style="-fx-font-size: 14px; -fx-background-radius: 5; -fx-border-color: #cccccc; -fx-border-radius: 5;"
                                   prefHeight="40"/>
                    </VBox>

                    <!-- Password Field -->
                    <VBox spacing="5">
                        <Label text="Password *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                        <PasswordField fx:id="passwordField"
                                       promptText="Create a strong password"
                                       style="-fx-font-size: 14px; -fx-background-radius: 5; -fx-border-color: #cccccc; -fx-border-radius: 5;"
                                       prefHeight="40"/>
                        <Label text="Minimum 6 characters"
                               style="-fx-font-size: 11px; -fx-text-fill: #999999;"/>
                    </VBox>

                    <!-- Confirm Password Field -->
                    <VBox spacing="5">
                        <Label text="Confirm Password *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                        <PasswordField fx:id="confirmPasswordField"
                                       promptText="Re-enter your password"
                                       style="-fx-font-size: 14px; -fx-background-radius: 5; -fx-border-color: #cccccc; -fx-border-radius: 5;"
                                       prefHeight="40"/>
                    </VBox>

                    <!-- Error Label -->
                    <Label fx:id="errorLabel"
                           text="Error message"
                           style="-fx-text-fill: #d32f2f; -fx-font-size: 13px; -fx-wrap-text: true; -fx-font-weight: bold;"
                           wrapText="true"
                           visible="false"/>

                    <!-- Success Label -->
                    <Label fx:id="successLabel"
                           text="Success message"
                           style="-fx-text-fill: #2e7d32; -fx-font-size: 13px; -fx-wrap-text: true; -fx-font-weight: bold;"
                           wrapText="true"
                           visible="false"/>

                    <!-- Register Button -->
                    <Button fx:id="registerButton" text="Create Account"
                            onAction="#handleRegister"
                            style="-fx-background-color: #C19A6B; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"
                            prefWidth="370" prefHeight="45">
                        <VBox.margin>
                            <Insets top="10"/>
                        </VBox.margin>
                    </Button>

                    <!-- Divider -->
                    <HBox alignment="CENTER" spacing="10">
                        <VBox.margin>
                            <Insets top="5" bottom="5"/>
                        </VBox.margin>
                        <Separator prefWidth="160" HBox.hgrow="ALWAYS"/>
                        <Label text="OR" style="-fx-font-size: 12px; -fx-text-fill: #999999;"/>
                        <Separator prefWidth="160" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <!-- Back to Login Button -->
                    <Button fx:id="backButton" text="← Already have an account? Sign In"
                            onAction="#handleBack"
                            style="-fx-background-color: transparent; -fx-text-fill: #C19A6B; -fx-font-size: 13px; -fx-cursor: hand; -fx-underline: true; -fx-font-weight: bold;"
                            prefWidth="370" prefHeight="35"/>
                </VBox>

                <!-- Terms Text -->
                <VBox alignment="CENTER" spacing="5">
                    <VBox.margin>
                        <Insets top="10"/>
                    </VBox.margin>
                    <Label text="By creating an account, you agree to our"
                           style="-fx-font-size: 11px; -fx-text-fill: #999999;"/>
                    <Label text="Terms of Service and Privacy Policy"
                           style="-fx-font-size: 11px; -fx-text-fill: #999999;"/>
                </VBox>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-padding: 20;">
            <Label text="© 2026 Peelin' Good Bakery - Workshop 5" style="-fx-font-size: 12px; -fx-text-fill: #999999;"/>
        </HBox>
    </bottom>
</BorderPane>

