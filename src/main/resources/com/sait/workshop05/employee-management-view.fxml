<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.6"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sait.workshop05.controllers.EmployeeManagementController"
            prefWidth="1200" prefHeight="800"
            styleClass="page-root">

    <children>

        <VBox spacing="12"
              AnchorPane.topAnchor="0"
              AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0"
              fillWidth="true">

            <padding>
                <Insets top="14" right="14" bottom="14" left="14"/>
            </padding>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Employee Management" styleClass="page-title"/>

                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtSearch" promptText="Search employees..."
                           prefWidth="260" styleClass="toolbar-search"/>
                <Button fx:id="btnRefresh" text="Refresh" onAction="#onRefresh"
                        styleClass="btn-muted toolbar-action"/>
                <Button fx:id="btnNewEmployee" text="New Employee" onAction="#onNewEmployee"
                        styleClass="btn-accent toolbar-action"/>
            </HBox>

            <!-- Table -->
            <TableView fx:id="tblEmployees" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colFirstName" text="FIRST NAME" prefWidth="130"/>
                    <TableColumn fx:id="colLastName" text="LAST NAME" prefWidth="130"/>
                    <TableColumn fx:id="colRole" text="ROLE" prefWidth="140"/>
                    <TableColumn fx:id="colBakery" text="BAKERY" prefWidth="160"/>
                    <TableColumn fx:id="colPhone" text="PHONE" prefWidth="140"/>
                    <TableColumn fx:id="colEmail" text="EMAIL" prefWidth="220"/>
                    <TableColumn fx:id="colAddress" text="ADDRESS" prefWidth="230"/>
                    <TableColumn fx:id="colActions" text="" prefWidth="130"/>
                </columns>
            </TableView>

            <Label fx:id="lblStatus" text="" styleClass="hint-label"/>
        </VBox>
    </children>
</AnchorPane>
