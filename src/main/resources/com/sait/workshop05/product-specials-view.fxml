<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.6"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sait.workshop05.controllers.ProductSpecialsController"
            styleClass="page-root">
    <children>
        <VBox spacing="16" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <!-- Toolbar -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtSearch" promptText="Search product specials..."
                           prefWidth="300" prefHeight="36"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnRefresh" text="Refresh" onAction="#onRefresh"
                        styleClass="btn-muted toolbar-action"/>
                <Button fx:id="btnNewSpecial" text="New Special" onAction="#onNewSpecial"
                        styleClass="btn-accent toolbar-action"/>
            </HBox>

            <!-- Table — productSpecialId (PK) is intentionally omitted -->
            <TableView fx:id="tblProductSpecials" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colProductName" text="PRODUCT"      prefWidth="180"/>
                    <TableColumn fx:id="colDescription"  text="DESCRIPTION"  prefWidth="280"/>
                    <TableColumn fx:id="colBasePrice"    text="BASE PRICE"   prefWidth="100"/>
                    <TableColumn fx:id="colDiscount"     text="DISCOUNT"     prefWidth="90"/>
                    <TableColumn fx:id="colFeaturedOn"   text="FEATURED ON"  prefWidth="120"/>
                    <TableColumn fx:id="colImage"        text="IMAGE"        prefWidth="100" minWidth="88"/>
                    <TableColumn fx:id="colActions"      text=""             prefWidth="130"/>
                </columns>
            </TableView>

            <Label fx:id="lblStatus" text="" styleClass="hint-label"/>
        </VBox>
    </children>
</AnchorPane>
