<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.6"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sait.workshop05.controllers.BakeryLocationsController"
            styleClass="page-root">
    <children>
        <VBox spacing="16" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <!-- Toolbar -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtSearch" promptText="Search bakeries..."
                           prefWidth="300" prefHeight="36"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnRefresh" text="Refresh" onAction="#onRefresh"
                        styleClass="btn-muted toolbar-action"/>
                <Button fx:id="btnNewBakery" text="New Location" onAction="#onNewBakery"
                        styleClass="btn-accent toolbar-action"/>
            </HBox>

            <!-- Table -->
            <TableView fx:id="tblBakeryLocations" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colBakeryId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colBakeryName" text="NAME" prefWidth="160"/>
                    <TableColumn fx:id="colBakeryPhone" text="PHONE" prefWidth="130"/>
                    <TableColumn fx:id="colBakeryEmail" text="EMAIL" prefWidth="200"/>
                    <TableColumn fx:id="colBakeryAddress" text="ADDRESS" prefWidth="160"/>
                    <TableColumn fx:id="colBakeryCity" text="CITY" prefWidth="100"/>
                    <TableColumn fx:id="colBakeryProvince" text="PROV" prefWidth="70"/>
                    <TableColumn fx:id="colActions" text="" prefWidth="130"/>
                </columns>
            </TableView>

            <Label fx:id="lblStatus" text="" styleClass="hint-label"/>
        </VBox>
    </children>
</AnchorPane>
