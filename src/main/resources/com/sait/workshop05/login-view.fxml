<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sait.workshop05.controllers.LoginController"
      prefHeight="600.0" prefWidth="900.0">

    <!-- Left brand panel -->
    <VBox HBox.hgrow="ALWAYS" maxWidth="400" alignment="CENTER" spacing="20"
          styleClass="login-brand-panel">
        <padding><Insets top="60" right="48" bottom="60" left="48"/></padding>

        <ImageView fitHeight="48" fitWidth="220" pickOnBounds="true" preserveRatio="true">
            <image><Image smooth="true" url="@bakery_logo.png"/></image>
        </ImageView>

        <Label text="Management System" styleClass="login-brand-title">
            <VBox.margin><Insets top="12"/></VBox.margin>
        </Label>

        <Label text="Staff-only access. Contact your administrator for login credentials."
               styleClass="login-brand-tagline" wrapText="true" textAlignment="CENTER"/>
    </VBox>

    <!-- Right form panel -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="login-right-panel">
        <padding><Insets top="60" right="60" bottom="60" left="60"/></padding>

        <VBox alignment="CENTER_LEFT" spacing="24"
              styleClass="login-card" maxWidth="380" prefWidth="380">

            <VBox spacing="4">
                <Label text="Welcome back" styleClass="login-card-title"/>
                <Label text="Sign in to your account" styleClass="login-card-subtitle"/>
            </VBox>

            <VBox spacing="16" prefWidth="320">

                <VBox spacing="6">
                    <Label text="Email or username" styleClass="form-label"/>
                    <TextField fx:id="loginIdField"
                               promptText="you@example.com or username"
                               prefHeight="42"
                               maxWidth="1.7976931348623157E308"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Password" styleClass="form-label"/>
                    <HBox spacing="0">
                        <StackPane HBox.hgrow="ALWAYS">
                            <PasswordField fx:id="passwordField"
                                          promptText="••••••••"
                                          prefHeight="42"
                                          style="-fx-background-radius: 8 0 0 8; -fx-border-radius: 8 0 0 8;"/>
                            <TextField fx:id="passwordVisible"
                                       promptText="••••••••"
                                       prefHeight="42"
                                       visible="false" managed="false"
                                       style="-fx-background-radius: 8 0 0 8; -fx-border-radius: 8 0 0 8;"/>
                        </StackPane>
                        <Button fx:id="togglePasswordBtn"
                                text="Show"
                                onAction="#handleTogglePassword"
                                minWidth="88" prefWidth="88"
                                styleClass="btn-login-toggle"/>
                    </HBox>
                </VBox>

                <Label fx:id="errorLabel"
                       text=""
                       styleClass="error-text"
                       wrapText="true"
                       visible="false"/>

                <Button fx:id="loginButton"
                        text="Sign In"
                        onAction="#handleLogin"
                        styleClass="btn-cta"
                        maxWidth="1.7976931348623157E308"
                        prefHeight="44">
                    <VBox.margin><Insets top="4"/></VBox.margin>
                </Button>

            </VBox>

            <Label text="Contact your administrator for access" styleClass="login-hint"/>

        </VBox>
    </VBox>

</HBox>
