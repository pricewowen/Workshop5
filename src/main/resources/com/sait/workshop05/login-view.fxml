<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sait.workshop05.controllers.LoginController"
      prefHeight="600.0" prefWidth="900.0">

    <!-- Left brand panel -->
    <VBox HBox.hgrow="ALWAYS" maxWidth="400" alignment="CENTER" spacing="20"
          styleClass="login-brand-panel">
        <padding><Insets top="60" right="48" bottom="60" left="48"/></padding>

        <ImageView fitHeight="250" fitWidth="500" pickOnBounds="true" preserveRatio="true">
            <image><Image smooth="true" url="@bakery_logo.png"/></image>
        </ImageView>

        <Label text="Management System" styleClass="login-brand-title">
            <VBox.margin><Insets top="12"/></VBox.margin>
        </Label>

        <Label text="Staff-only access. Contact your administrator for login credentials."
               styleClass="login-brand-tagline" wrapText="true" textAlignment="CENTER"/>
    </VBox>

    <!-- Right form panel -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="login-right-panel">
        <padding><Insets top="60" right="60" bottom="60" left="60"/></padding>

        <VBox alignment="CENTER_LEFT" spacing="24"
              styleClass="login-card" maxWidth="380" prefWidth="380">

            <VBox spacing="4">
                <Label text="Welcome back" styleClass="login-card-title"/>
                <Label text="Sign in to your account" styleClass="login-card-subtitle"/>
            </VBox>

            <VBox spacing="16" prefWidth="320">

                <VBox spacing="6">
                    <Label text="Email or username" styleClass="form-label"/>
                    <TextField fx:id="loginIdField"
                               promptText="you@example.com or username"
                               prefHeight="42"
                               maxWidth="1.7976931348623157E308"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Password" styleClass="form-label"/>
                    <StackPane>
                        <PasswordField fx:id="passwordField"
                                      promptText="••••••••"
                                      prefHeight="42"
                                      style="-fx-padding: 0 42 0 12;"/>
                        <TextField fx:id="passwordVisible"
                                   promptText="••••••••"
                                   prefHeight="42"
                                   visible="false" managed="false"
                                   style="-fx-padding: 0 42 0 12;"/>
                        <Button fx:id="togglePasswordBtn"
                                onAction="#handleTogglePassword"
                                focusTraversable="false"
                                styleClass="btn-password-toggle"
                                StackPane.alignment="CENTER_RIGHT">
                            <StackPane.margin>
                                <Insets right="6"/>
                            </StackPane.margin>
                            <graphic>
                                <SVGPath fx:id="iconEye"
                                         content="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5C21.27 7.61 17 4.5 12 4.5zm0 12.5c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                                         fill="#6B5B4E"
                                         scaleX="0.75" scaleY="0.75"/>
                            </graphic>
                        </Button>
                    </StackPane>
                </VBox>

                <Label fx:id="errorLabel"
                       styleClass="error-text"
                       wrapText="true"
                       visible="false" managed="true"/>

                <Button fx:id="loginButton"
                        text="Sign In"
                        onAction="#handleLogin"
                        defaultButton="true"
                        prefHeight="44"
                        maxWidth="1.7976931348623157E308"
                        styleClass="btn-primary"/>

                <VBox alignment="CENTER" spacing="5">
                    <VBox.margin>
                        <Insets top="10"/>
                    </VBox.margin>
                    <Label text="Contact your administrator for login credentials" styleClass="login-hint"/>
                </VBox>
            </VBox>
        </VBox>
    </VBox>

</HBox>
