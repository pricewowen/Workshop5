<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sait.workshop05.controllers.LoginController"
            prefHeight="600.0" prefWidth="800.0"
            styleClass="login-root">

    <center>
        <VBox alignment="CENTER" spacing="30">
            <padding>
                <Insets top="50" right="50" bottom="50" left="50"/>
            </padding>

            <VBox alignment="CENTER" spacing="25"
                  styleClass="login-card"
                  prefWidth="400" maxWidth="400">

                <VBox alignment="CENTER" spacing="10">
                    <ImageView fitHeight="80.0" fitWidth="320.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image smooth="true" url="@bakery_logo.png"/>
                        </image>
                    </ImageView>
                    <Label text="Management System" styleClass="login-title"/>
                </VBox>

                <Separator prefWidth="320"/>

                <VBox spacing="15" prefWidth="320">
                    <VBox spacing="5">
                        <Label text="Email" styleClass="form-label"/>
                        <TextField fx:id="emailField"
                                   promptText="Enter your email"
                                   prefHeight="40"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Password" styleClass="form-label"/>
                        <HBox spacing="0" prefHeight="40">
                            <StackPane HBox.hgrow="ALWAYS">
                                <PasswordField fx:id="passwordField"
                                              promptText="Enter your password"
                                              prefHeight="40"
                                              style="-fx-background-radius: 4 0 0 4;"/>
                                <TextField fx:id="passwordVisible"
                                           promptText="Enter your password"
                                           prefHeight="40"
                                           visible="false"
                                           managed="false"
                                           style="-fx-background-radius: 4 0 0 4;"/>
                            </StackPane>
                            <Button fx:id="togglePasswordBtn"
                                    text="Show"
                                    onAction="#handleTogglePassword"
                                    prefHeight="40" prefWidth="60"
                                    styleClass="toggle-password-btn"
                                    style="-fx-background-radius: 0 4 4 0;"/>
                        </HBox>
                    </VBox>

                    <Label fx:id="errorLabel"
                           text="Error message"
                           styleClass="error-text"
                           wrapText="true"
                           visible="false"/>

                    <Button fx:id="loginButton" text="Login"
                            onAction="#handleLogin"
                            styleClass="btn-cta"
                            prefWidth="320" prefHeight="45">
                        <VBox.margin>
                            <Insets top="10"/>
                        </VBox.margin>
                    </Button>
                </VBox>

                <VBox alignment="CENTER" spacing="5">
                    <VBox.margin>
                        <Insets top="10"/>
                    </VBox.margin>
                    <Label text="Contact your administrator for login credentials" styleClass="login-hint"/>
                </VBox>
            </VBox>
        </VBox>
    </center>

</BorderPane>
