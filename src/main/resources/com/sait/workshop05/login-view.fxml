<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sait.workshop05.LoginController"
            prefHeight="600.0" prefWidth="800.0"
            style="-fx-background-color: #f5f5f5;">

    <center>
        <VBox alignment="CENTER" spacing="30">
            <padding>
                <Insets top="50" right="50" bottom="50" left="50"/>
            </padding>

            <!-- Login Card -->
            <VBox alignment="CENTER" spacing="25"
                  style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);"
                  prefWidth="400" maxWidth="400">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>

                <!-- Header -->
                <VBox alignment="CENTER" spacing="10">
                    <Label text="🥐 Peelin' Good Bakery" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #C19A6B;"/>
                    <Label fx:id="roleLabel" text="Login" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                </VBox>

                <Separator prefWidth="320"/>

                <!-- Login Form -->
                <VBox spacing="15" prefWidth="320">
                    <!-- Username Field -->
                    <VBox spacing="5">
                        <Label text="Username" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                        <TextField fx:id="usernameField"
                                   promptText="Enter your username"
                                   style="-fx-font-size: 14px; -fx-background-radius: 5; -fx-border-color: #cccccc; -fx-border-radius: 5;"
                                   prefHeight="40"/>
                    </VBox>

                    <!-- Password Field -->
                    <VBox spacing="5">
                        <Label text="Password" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                        <PasswordField fx:id="passwordField"
                                       promptText="Enter your password"
                                       style="-fx-font-size: 14px; -fx-background-radius: 5; -fx-border-color: #cccccc; -fx-border-radius: 5;"
                                       prefHeight="40"/>
                    </VBox>

                    <!-- Error Label -->
                    <Label fx:id="errorLabel"
                           text="Error message"
                           style="-fx-text-fill: #d32f2f; -fx-font-size: 13px; -fx-wrap-text: true;"
                           wrapText="true"
                           visible="false"/>

                    <!-- Login Button -->
                    <Button fx:id="loginButton" text="Login"
                            onAction="#handleLogin"
                            style="-fx-background-color: #C19A6B; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"
                            prefWidth="320" prefHeight="45">
                        <VBox.margin>
                            <Insets top="10"/>
                        </VBox.margin>
                    </Button>

                    <!-- Divider -->
                    <HBox alignment="CENTER" spacing="10">
                        <VBox.margin>
                            <Insets top="10" bottom="10"/>
                        </VBox.margin>
                        <Separator prefWidth="140" HBox.hgrow="ALWAYS"/>
                        <Label text="OR" style="-fx-font-size: 12px; -fx-text-fill: #999999;"/>
                        <Separator prefWidth="140" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <!-- Register Button -->
                    <Button fx:id="registerButton" text="Create New Account"
                            onAction="#handleRegister"
                            style="-fx-background-color: #8B7355; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"
                            prefWidth="320" prefHeight="40"/>

                    <!-- Back Button -->
                    <Button fx:id="backButton" text="← Back to Role Selection"
                            onAction="#handleBack"
                            style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 13px; -fx-cursor: hand; -fx-underline: true;"
                            prefWidth="320" prefHeight="30">
                        <VBox.margin>
                            <Insets top="5"/>
                        </VBox.margin>
                    </Button>
                </VBox>

                <!-- Help Text -->
                <VBox alignment="CENTER" spacing="5">
                    <VBox.margin>
                        <Insets top="10"/>
                    </VBox.margin>
                    <Label text="Need help logging in?" style="-fx-font-size: 12px; -fx-text-fill: #999999;"/>
                    <Label text="Contact support at support@peelingood.com" style="-fx-font-size: 11px; -fx-text-fill: #999999;"/>
                </VBox>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-padding: 20;">
            <Label text="© 2026 Peelin' Good Bakery - Workshop 5" style="-fx-font-size: 12px; -fx-text-fill: #999999;"/>
        </HBox>
    </bottom>
</BorderPane>

