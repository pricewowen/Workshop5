<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.6"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sait.workshop05.controllers.DashboardController"
            style="-fx-background-color: white;">

    <children>

        <VBox spacing="16"
              AnchorPane.topAnchor="0"
              AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0"
              fillWidth="true">

            <padding>
                <Insets top="14" right="14" bottom="14" left="14"/>
            </padding>

            <!-- ── Page header ──────────────────────────────── -->
            <HBox alignment="CENTER_LEFT" spacing="14">
                <ImageView fitHeight="48.0" fitWidth="220.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image smooth="true" url="@bakery_logo.png"/>
                    </image>
                </ImageView>
                <VBox spacing="2">
                    <Label text="Dashboard Overview">
                        <font><Font size="24"/></font>
                    </Label>
                    <Label text="Home / Dashboard"
                           style="-fx-text-fill: #888; -fx-font-size: 12px;"/>
                </VBox>
            </HBox>

            <!-- ── Summary cards row ────────────────────────── -->
            <HBox spacing="14" alignment="CENTER">

                <!-- Revenue card -->
                <VBox alignment="CENTER_LEFT" spacing="4"
                      HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"
                      style="-fx-background-color: #fff8e1; -fx-background-radius: 8; -fx-border-color: #f0e6c0; -fx-border-radius: 8;">
                    <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                    <Label fx:id="lblTotalRevenu" text="\$0.00"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #5a4e00;"/>
                    <Label text="Total Revenue"
                           style="-fx-font-size: 14px; -fx-text-fill: #8a7e3e;"/>
                </VBox>

                <!-- Orders card -->
                <VBox alignment="CENTER_LEFT" spacing="4"
                      HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"
                      style="-fx-background-color: #e8f5e9; -fx-background-radius: 8; -fx-border-color: #c8e6c9; -fx-border-radius: 8;">
                    <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                    <Label fx:id="lblTotalOrders" text="0"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
                    <Label text="Total Orders"
                           style="-fx-font-size: 14px; -fx-text-fill: #558b2f;"/>
                </VBox>

                <!-- Customers card -->
                <VBox alignment="CENTER_LEFT" spacing="4"
                      HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"
                      style="-fx-background-color: #e3f2fd; -fx-background-radius: 8; -fx-border-color: #bbdefb; -fx-border-radius: 8;">
                    <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                    <Label fx:id="lblTotalCustomers" text="0"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                    <Label text="Total Customers"
                           style="-fx-font-size: 14px; -fx-text-fill: #1976d2;"/>
                </VBox>

                <!-- Products card -->
                <VBox alignment="CENTER_LEFT" spacing="4"
                      HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"
                      style="-fx-background-color: #fce4ec; -fx-background-radius: 8; -fx-border-color: #f8bbd0; -fx-border-radius: 8;">
                    <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                    <Label fx:id="lblActiveProducts" text="0"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #ad1457;"/>
                    <Label text="Active Products"
                           style="-fx-font-size: 14px; -fx-text-fill: #c2185b;"/>
                </VBox>

            </HBox>

            <!-- ── Recent orders section ────────────────────── -->
            <VBox spacing="10" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #fafafa; -fx-background-radius: 8; -fx-border-color: #e6e6e6; -fx-border-radius: 8;">

                <padding><Insets top="12" right="14" bottom="14" left="14"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Recent Orders"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnRefresh" text="Refresh" onAction="#onRefresh"
                            style="-fx-font-size: 13px;" prefHeight="32"/>
                    <Button fx:id="btnNewOrder" text="+ New Order"
                            style="-fx-font-size: 13px; -fx-font-weight: bold;" prefHeight="32"/>
                </HBox>

                <TableView fx:id="tbvRecentOrders" VBox.vgrow="ALWAYS"
                           style="-fx-font-size: 13px;">
                    <columns>
                        <TableColumn fx:id="colOrderId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colCustomer" text="Customer" prefWidth="140"/>
                        <TableColumn fx:id="colProducts" text="Products" prefWidth="200"/>
                        <TableColumn fx:id="colTotal" text="Total" prefWidth="90"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="130"/>
                        <TableColumn fx:id="colActions" text="" prefWidth="80"/>
                    </columns>
                </TableView>

                <Label fx:id="lblStatus" text=""
                       style="-fx-text-fill: #888; -fx-font-size: 12px;"/>

            </VBox>

        </VBox>

    </children>

</AnchorPane>
