<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sait.workshop05.RewardTierController"
            prefWidth="1200" prefHeight="800"
            styleClass="page-root">
    <children>
        <VBox spacing="12"
              AnchorPane.topAnchor="0"
              AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0"
              fillWidth="true">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14"/>
            </padding>

            <!-- Header -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Reward Tier Management" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Search:" style="-fx-font-size: 13px;"/>
                <TextField fx:id="txtSearch"
                           promptText="Search tiers..."
                           prefWidth="420" prefHeight="36"
                           style="-fx-font-size: 13px;"/>
                <Button text="Refresh"
                        fx:id="btnRefresh"
                        onAction="#onRefresh"
                        prefWidth="100"
                        styleClass="btn-muted toolbar-action"/>
            </HBox>

            <!-- Main Content -->
            <SplitPane dividerPositions="0.70" VBox.vgrow="ALWAYS" prefWidth="1.0" prefHeight="1.0">
                <items>
                    <!-- Table View -->
                    <VBox spacing="10" SplitPane.resizableWithParent="true" fillWidth="true">
                        <TableView fx:id="tblRewardTiers"
                                   VBox.vgrow="ALWAYS"
                                   prefWidth="1.0"
                                   style="-fx-font-size: 13px;">
                            <fixedCellSize>28</fixedCellSize>
                            <columns>
                                <TableColumn fx:id="colTierId" text="ID" prefWidth="60"/>
                                <TableColumn fx:id="colTierName" text="Tier Name" prefWidth="150"/>
                                <TableColumn fx:id="colMinPoints" text="Min Points" prefWidth="100"/>
                                <TableColumn fx:id="colMaxPoints" text="Max Points" prefWidth="100"/>
                                <TableColumn fx:id="colDiscountRate" text="Discount %" prefWidth="100"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                        <Label fx:id="lblStatus"
                               text="0 tier(s) loaded"
                               style="-fx-text-fill: #444; -fx-font-size: 13px;"/>
                    </VBox>

                    <!-- Detail Panel -->
                    <ScrollPane fitToWidth="true"
                                fitToHeight="true"
                                hbarPolicy="NEVER"
                                vbarPolicy="AS_NEEDED"
                                prefWidth="420"
                                SplitPane.resizableWithParent="true">
                        <content>
                            <VBox spacing="14"
                                  fillWidth="true"
                                  prefWidth="1.0"
                                  styleClass="form-panel">
                                <padding>
                                    <Insets top="16" right="16" bottom="16" left="16"/>
                                </padding>

                                <Label text="Reward Tier Details"
                                       styleClass="form-panel-title"/>

                                <GridPane hgap="12" vgap="12" prefWidth="1.0">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="120"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>

                                    <Label text="Tier ID:"
                                           style="-fx-font-size: 13px;"
                                           GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                    <TextField fx:id="txtTierId"
                                               editable="false"
                                               promptText="Auto"
                                               style="-fx-font-size: 13px;"
                                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                    <Label text="Tier Name *:"
                                           style="-fx-font-size: 13px;"
                                           GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                    <TextField fx:id="txtTierName"
                                               promptText="e.g., Bronze, Silver, Gold"
                                               style="-fx-font-size: 13px;"
                                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                    <Label text="Min Points *:"
                                           style="-fx-font-size: 13px;"
                                           GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                    <TextField fx:id="txtMinPoints"
                                               promptText="0"
                                               style="-fx-font-size: 13px;"
                                               GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                    <Label text="Max Points:"
                                           style="-fx-font-size: 13px;"
                                           GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                    <HBox spacing="5" GridPane.rowIndex="3" GridPane.columnIndex="1">
                                        <TextField fx:id="txtMaxPoints"
                                                   promptText="Leave empty for unlimited"
                                                   prefWidth="200"
                                                   style="-fx-font-size: 13px;"/>
                                        <CheckBox fx:id="chkUnlimited"
                                                  style="-fx-font-size: 13px;"/>
                                    </HBox>

                                    <Label text="Discount Rate %:"
                                           style="-fx-font-size: 13px;"
                                           GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                    <TextField fx:id="txtDiscountRate"
                                               promptText="0.00"
                                               style="-fx-font-size: 13px;"
                                               GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                                </GridPane>

                                <Separator/>

                                <!-- Buttons -->
                                <GridPane hgap="12" vgap="12">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10"/>
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10"/>
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="38" vgrow="NEVER"/>
                                        <RowConstraints minHeight="38" vgrow="NEVER"/>
                                    </rowConstraints>
                                    <Button text="Create" fx:id="btnCreate"
                                            onAction="#onCreate"
                                            styleClass="btn-muted toolbar-action"
                                            maxWidth="1.7976931348623157E308"
                                            GridPane.rowIndex="0" GridPane.columnIndex="0" GridPane.hgrow="ALWAYS"/>
                                    <Button text="Update" fx:id="btnUpdate"
                                            onAction="#onUpdate"
                                            styleClass="btn-muted toolbar-action"
                                            maxWidth="1.7976931348623157E308"
                                            GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS"/>
                                    <Button text="Delete" fx:id="btnDelete"
                                            onAction="#onDelete"
                                            styleClass="danger-button toolbar-action"
                                            maxWidth="1.7976931348623157E308"
                                            GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.hgrow="ALWAYS"/>
                                    <Button text="Clear" fx:id="btnClear"
                                            onAction="#onClear"
                                            styleClass="btn-muted toolbar-action"
                                            maxWidth="1.7976931348623157E308"
                                            GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS"/>
                                </GridPane>

                                <Label text="* required fields"
                                       style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                            </VBox>
                        </content>
                    </ScrollPane>
                </items>
            </SplitPane>
        </VBox>
    </children>
</AnchorPane>